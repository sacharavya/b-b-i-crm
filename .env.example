# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Microsoft Graph
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
# Email/UPN of the user whose OneDrive holds case files (e.g. info@bigbangimmigration.com)
GRAPH_ONEDRIVE_USER=
# Drive id returned by `npm run graph:test` after GRAPH_ONEDRIVE_USER is set
GRAPH_DOCUMENT_LIBRARY_ID=
# Optional: anchor case folders inside this top-level folder in the drive.
# Useful for sandboxing during development (e.g. "Test-CRM"). Leave blank to
# anchor at drive root. Slashes allowed for nesting: "Sandbox/Cases".
GRAPH_ROOT_FOLDER=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_ADDRESS=

# Error monitoring (Sentry)
SENTRY_DSN=
